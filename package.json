{
  "name": "web-ftp-client",
  "version": "1.0.0",
  "description": "Web-based FTP client with file manager interface",
  "type": "module",
  "main": "server/server.ts",
  "scripts": {
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "start": "tsx server/server.ts",
    "frontend": "tsx server/frontend-server.ts",
    "dev": "nodemon --exec tsx server/server.ts",
    "dev:frontend": "nodemon --exec tsx server/frontend-server.ts",
    "watch:frontend": "tsc -p tsconfig.frontend.json --watch"
  },
  "dependencies": {
    "basic-ftp": "^5.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
